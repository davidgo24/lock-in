generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  displayName  String?
  /// Lowercase unique @handle without the @ (3–30 chars [a-z0-9_], set via API).
  handle            String?   @unique
  /// When set and in the future, friends may show “in focus” (synced while a timer is running).
  activeFocusEndsAt DateTime?
  /// Focus area for the active timer — friends may show the label (must be this user’s project).
  activeFocusProjectId String?
  activeFocusProject   Project? @relation("UserActiveFocusProject", fields: [activeFocusProjectId], references: [id], onDelete: SetNull)
  /// Optional profile picture (served from /api/avatar/[userId] for self + friends).
  avatarBytes       Bytes?
  avatarMime        String?
  createdAt         DateTime  @default(now())
  projects     Project[]
  settings     AppSettings?

  @@index([activeFocusProjectId])

  sentFriendRequests     FriendRequest[] @relation("FriendRequestFrom")
  receivedFriendRequests FriendRequest[] @relation("FriendRequestTo")
  friendshipsAsA         Friendship[]    @relation("FriendshipUserA")
  friendshipsAsB         Friendship[]    @relation("FriendshipUserB")
  activityClaps          ActivityClap[]
  activityComments       ActivityComment[]
  notificationsReceived  ActivityNotification[] @relation("ActivityNotifRecipient")
  notificationsAsActor   ActivityNotification[] @relation("ActivityNotifActor")
}

enum ActivityNotificationType {
  CLAP
  COMMENT
}

/// Pending invite — mutual friendship created only after `toUser` accepts.
model FriendRequest {
  id         String   @id @default(cuid())
  fromUserId String
  toUserId   String
  fromUser   User     @relation("FriendRequestFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser     User     @relation("FriendRequestTo", fields: [toUserId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([fromUserId, toUserId])
  @@index([toUserId])
  @@index([fromUserId])
}

/// Accepted mutual friends only; `userAId` is lexicographically < `userBId`.
model Friendship {
  userAId   String
  userBId   String
  userA     User     @relation("FriendshipUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB     User     @relation("FriendshipUserB", fields: [userBId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userAId, userBId])
  @@index([userBId])
}

model AppSettings {
  userId          String @id
  user            User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  weeklyGoalHours Float  @default(7)
}

model Project {
  id        String            @id @default(cuid())
  userId    String
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  isMisc    Boolean           @default(false)
  /// When set, hidden from timer picker; sessions and stats are kept.
  archivedAt DateTime?
  createdAt DateTime          @default(now())
  sessions  ActivitySession[]
  usersWithThisAsActiveFocus User[] @relation("UserActiveFocusProject")

  @@index([userId])
  @@index([isMisc])
  @@index([userId, isMisc])
  @@index([userId, archivedAt])
}

model ActivitySession {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  /// What you accomplished (log note)
  summary     String
  durationSec Int
  /// Calendar day for heatmap (Postgres DATE)
  workDate    DateTime @db.Date
  createdAt   DateTime @default(now())
  claps       ActivityClap[]
  comments    ActivityComment[]
  notifications ActivityNotification[]

  @@index([workDate])
  @@index([projectId])
}

/// One reaction (emoji) per user per session (friend activity).
model ActivityClap {
  sessionId String
  userId    String
  /// Single grapheme shown in the feed (validated in application code).
  emoji     String   @default("👏")
  session   ActivitySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now())

  @@id([sessionId, userId])
  @@index([userId])
}

/// Conversation on a session: friends and the session owner can post multiple comments over time.
model ActivityComment {
  id        String          @id @default(cuid())
  sessionId String
  userId    String
  body      String
  session   ActivitySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([sessionId])
  @@index([sessionId, userId])
}

model ActivityNotification {
  id          String                   @id @default(cuid())
  recipientId String
  actorId     String
  type        ActivityNotificationType
  sessionId   String
  readAt      DateTime?
  createdAt   DateTime                 @default(now())
  recipient   User                     @relation("ActivityNotifRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actor       User                     @relation("ActivityNotifActor", fields: [actorId], references: [id], onDelete: Cascade)
  session     ActivitySession          @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([recipientId, readAt])
  @@index([recipientId, createdAt])
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  displayName  String?
  createdAt    DateTime  @default(now())
  projects     Project[]
  settings     AppSettings?
}

model AppSettings {
  userId          String @id
  user            User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  weeklyGoalHours Float  @default(7)
}

model Project {
  id        String            @id @default(cuid())
  userId    String
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  isMisc    Boolean           @default(false)
  createdAt DateTime          @default(now())
  sessions  ActivitySession[]

  @@index([userId])
  @@index([isMisc])
  @@index([userId, isMisc])
}

model ActivitySession {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  /// What you accomplished (log note)
  summary     String
  durationSec Int
  /// Calendar day for heatmap (Postgres DATE)
  workDate    DateTime @db.Date
  createdAt   DateTime @default(now())

  @@index([workDate])
  @@index([projectId])
}

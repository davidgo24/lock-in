# PostgreSQL (Railway: connect a Postgres service and paste DATABASE_URL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Single-user password for the login form
APP_PASSWORD="your-secret-password"

# Min 32 characters; use a long unguessable string in production
SESSION_SECRET="replace-with-a-random-32-plus-character-string"

# Shown on work entry cards (optional)
NEXT_PUBLIC_DISPLAY_NAME="You"

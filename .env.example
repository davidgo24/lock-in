# PostgreSQL (Railway: connect a Postgres service and paste DATABASE_URL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Min 32 characters; use a long unguessable string in production
SESSION_SECRET="replace-with-a-random-32-plus-character-string"

# Shown in the top bar / metadata (optional)
NEXT_PUBLIC_APP_NAME="5to9 Club"

# After running multi-user migration, sign in with:
# Email: owner@local.dev
# Password: password
# (Change this account’s password by creating a new user via /signup and migrating data if needed.)

# Optional: prisma/db seed (npm run db:seed)
# SEED_USER_EMAIL="demo@example.com"
# SEED_USER_PASSWORD="password"
